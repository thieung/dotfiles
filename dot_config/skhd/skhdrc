#

# Reload yabai 
ctrl + lalt + cmd - r : bash -c 'launchctl kickstart -k "gui/${UID}/homebrew.mxcl.yabai"'

## Open applications
alt + shift - b : open /Applications/Brave Browser.app # [b]rowser
alt + shift - c : open /Applications/Microsoft\ Teams\ \(work\ or\ school\).app # [c]ommunication
alt + shift - d : open /Applications/TablePlus.app # [d]atabase
alt + shift - f : open /Applications/Messenger.app # [f]acebook
alt + shift - g : open /Applications/GitButler.app # [g]it
alt + shift - m : open -a Mail.app # [m]ail
alt + shift - n : open /Applications/Notion.app # [n]ote
alt + shift - p : open /Applications/Postman.app # [p]ostman
alt + shift - o : open /Applications/Obsidian.app # [o]bsidian
alt + shift - s : open /Applications/Slack.app # [s]lack
alt + shift - t : open /Applications/kitty.app # [t]erminal

# Toggle fullscreen
alt - f : yabai -m window --toggle zoom-fullscreen

# Float/unfloat window and center on screen
shift + alt - space : yabai -m window --toggle float; yabai -m window --grid 4:4:1:1:2:2

## Navigation
# Space navigation
alt - x : yabai -m space --focus recent
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5

# Window navigation
ctrl + alt - h : yabai -m window --focus west
ctrl + alt - j : yabai -m window --focus south
ctrl + alt - k : yabai -m window --focus north
ctrl + alt - l : yabai -m window --focus east

## Movement
# Send focused window to space and follow focus
shift + alt - x : yabai -m window --space recent; yabai -m space --focus recent
shift + alt - 1 : yabai -m window --space 1; yabai -m space --focus 1
shift + alt - 2 : yabai -m window --space 2; yabai -m space --focus 2
shift + alt - 3 : yabai -m window --space 3; yabai -m space --focus 3
shift + alt - 4 : yabai -m window --space 4; yabai -m space --focus 4
shift + alt - 5 : yabai -m window --space 5; yabai -m space --focus 5

# Move focused window
shift + ctrl - h : yabai -m window --warp west
shift + ctrl - j : yabai -m window --warp south
shift + ctrl - k : yabai -m window --warp north
shift + ctrl - l : yabai -m window --warp east
